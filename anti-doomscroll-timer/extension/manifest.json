{
    "manifest_version": 3,
    "name": "Anti-Doomscroll Timer",
    "version": "1.0",
    "description": "Monitors YouTube Shorts and Instagram Reels to prevent-doomscrolling.",
    "permissions": [
        "tabs",
        "activeTab",
        "webNavigation",
        "nativeMessaging"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "host_permissions": [
        "*://*.youtube.com/*",
        "*://*.instagram.com/*"
    ],
    "key": "",
    "icons": {
        "128": "icon.png"
    }
}